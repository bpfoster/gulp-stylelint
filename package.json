{
  "name": "@ronilaukkarinen/gulp-stylelint",
  "version": "14.1.2",
  "type": "module",
  "description": "Gulp plugin for running Stylelint results through various reporters.",
  "main": "src/index.js",
  "files": [
    "/src/*.js"
  ],
  "exports": "./src/index.js",
  "scripts": {
    "lint": "eslint \"{src,test}/**/*.js\"",
    "tape": "tape \"test/*.spec.js\"",
    "test": "npm run lint && npm run tape",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ronilaukkarinen/gulp-stylelint.git"
  },
  "keywords": [
    "gulpplugin",
    "stylelint",
    "postcss",
    "css"
  ],
  "author": "Oleg Sklyanchuk <sklyanchuk@gmail.com> (http://olegskl.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ronilaukkarinen/gulp-stylelint/issues"
  },
  "homepage": "https://github.com/ronilaukkarinen/gulp-stylelint",
  "engines": {
    "node": ">=18.12.0"
  },
  "peerDependencies": {
    "stylelint": "10 - 15"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "ansi-colors": "^4.1.3",
    "fancy-log": "^2.0.0",
    "plugin-error": "^2.0.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "eslint": "^10.0.3",
    "eslint-config-stylelint": "^18.0.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-regexp": "^1.12.0",
    "globals": "^17.4.0",
    "gulp": "^4.0.2",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-rename": "^2.1.0",
    "gulp-sourcemaps": "^3.0.0",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "sinon": "^21.0.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "tape": "^5.9.0"
  },
  "eslintConfig": {
    "extends": [
      "stylelint"
    ],
    "parserOptions": {
      "ecmaVersion": 2022
    }
  }
}
